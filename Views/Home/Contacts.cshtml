@{
    Layout = "_Layout";
    ViewData["Title"] = "Home";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lindi's Bakery - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>
<body>

<!-- Contact Section -->
<section id="contact">
    <div class="contact container">
        <div>
            <h1 class="section-title">Contact <span>info</span></h1>
        </div>
        <div class="contact-items">
            <div class="contact-item">
                    <div class="icon"><img width="100" height="100" src="https://img.icons8.com/bubbles/100/ringer-volume.png" alt="ringer-volume" /></div>
                <div class="contact-info">
                    <h1>Phone</h1>
                        <h2><a href="tel:0797173580">0797173580</a></h2>
                </div>

            </div>
                <div class="contact-item">
                    <div class="icon"><img width="100" height="100" src="https://img.icons8.com/color/96/whatsapp--v1.png" alt="whatsapp--v1" /></div>
                    <div class="contact-info">
                        <h1>Whatsapp</h1>
                        <h2><a href="https://wa.me/0797173580">Whatsapp.me</a></h2>
                    </div>
                </div>

                <div class="contact-item">
                    <div class="icon"><img width="100" height="100" src="https://img.icons8.com/bubbles/100/gmail-new.png" alt="gmail-new" /></div>
                    <div class="contact-info">
                        <h1>Email</h1>
                        <h2><a href="mailto:michelkekana17@gmail.com">michelkekana17@gmail.com</a></h2>
                    </div>
                </div>

            <div class="contact-item">
                <div class="icon"><img width="100" height="100" src="https://img.icons8.com/bubbles/100/address.png" alt="address" /></div>
                <div class="contact-info">
                    <h1>Address</h1>
                    <a href="https://www.google.com/maps/search/?api=1&query=749+Uzangozolo+Street+Pretoria">
                        <h2>749 Zelkova Street<br>Block F West<br>Soshanguve<br>0152</h2>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- End Contact Section -->

    <script src="~/js/site.js"></script>

</body>
</html>