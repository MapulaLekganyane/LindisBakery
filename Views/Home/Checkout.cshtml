@model LindisBakery.Models.ShoppingCart

@{
    ViewData["Title"] = "Checkout";
}

<div class="checkout-wrapper">

    <h2 class="checkout-title">Checkout</h2>

    <form asp-action="Checkout" method="post">

        <!-- CUSTOMER DETAILS -->
        <h6 class="section-title">Customer Details</h6>

        <div class="form-group">
            <input type="text" name="CustomerName" class="form-control"
                   placeholder="Full Name" required />
        </div>

        <div class="form-group">
            <input type="email" name="Email" class="form-control"
                   placeholder="Email Address" required />
        </div>

        <div class="form-group">
            <input type="tel" name="Phone" class="form-control"
                   placeholder="Phone Number" required />
        </div>

        <!-- PAYMENT METHOD -->
        <h4 class="section-title">Payment Method</h4>

        <div class="payment-methods">

            <label class="payment-option">
                <input type="radio" name="PaymentMethod" value="Card" required>
                <span>💳 Card</span>
            </label>

            <label class="payment-option">
                <input type="radio" name="PaymentMethod" value="Cash">
                <span>💵 Cash</span>
            </label>

            <label class="payment-option">
                <input type="radio" name="PaymentMethod" value="Cash on Delivery">
                <span>🚚 Card on Delivery</span>
            </label>

        </div>

        <button type="submit" class="btn-pink place-order-btn">
            Place Order</button>

    </form>

</div>
