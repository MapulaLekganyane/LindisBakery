@model List<LindisBakery.Models.Order>
@{
    ViewData["Title"] = "Manage Orders";
}

<div class="container-fluid">
    <h1 class="h3 mb-4">Manage Orders</h1>

    <!-- Status Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="btn-group" role="group">
                <a asp-action="Orders" asp-route-status="All"
                   class="btn @(ViewBag.SelectedStatus == null ? "btn-primary" : "btn-outline-primary")">
                    All (@ViewBag.StatusCounts.All)
                </a>
                <a asp-action="Orders" asp-route-status="Pending"
                   class="btn @(ViewBag.SelectedStatus == "Pending" ? "btn-warning" : "btn-outline-warning")">
                    Pending (@ViewBag.StatusCounts.Pending)
                </a>
                <a asp-action="Orders" asp-route-status="Processing"
                   class="btn @(ViewBag.SelectedStatus == "Processing" ? "btn-info" : "btn-outline-info")">
                    Processing (@ViewBag.StatusCounts.Processing)
                </a>
                <a asp-action="Orders" asp-route-status="Completed"
                   class="btn @(ViewBag.SelectedStatus == "Completed" ? "btn-success" : "btn-outline-success")">
                    Completed (@ViewBag.StatusCounts.Completed)
                </a>
                <a asp-action="Orders" asp-route-status="Cancelled"
                   class="btn @(ViewBag.SelectedStatus == "Cancelled" ? "btn-danger" : "btn-outline-danger")">
                    Cancelled (@ViewBag.StatusCounts.Cancelled)
                </a>
            </div>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Orders List</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>@order.OrderNumber</td>
                                <td>@order.CustomerName</td>
                                <td>@order.CustomerEmail</td>
                                <td>@order.CustomerPhone</td>
                                <td>@order.OrderDate.ToString("g")</td>
                                <td>@order.Items.Sum(oi => oi.Quantity)</td>
                                <td>R @order.Total.ToString("F2")</td>
                                <td>
                                    <span class="badge
                                            @(order.Status == "Pending" ? "badge-warning" :
                                                                                    order.Status == "Processing" ? "badge-info" :
                                                                                    order.Status == "Completed" ? "badge-success" :
                                                                                    "badge-danger")">
                                    @order.Status
                                </span>
                            </td>
                            <td>
                                <a asp-action="OrderDetail" asp-route-id="@order.Id"
                                   class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-primary"
                                        data-toggle="modal" data-target="#statusModal-@order.Id">
                                    <i class="fas fa-edit"></i>
                                </button>
                            </td>
                        </tr>

                            <!-- Status Update Modal -->
                            <div class="modal fade" id="statusModal-@order.Id" tabindex="-1" role="dialog">
                                <div class="modal-dialog" role="document">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Update Order Status</h5>
                                            <button type="button" class="close" data-dismiss="modal">
                                                <span>&times;</span>
                                            </button>
                                        </div>
                                        <form asp-action="UpdateOrderStatus" asp-route-id="@order.Id" method="post">
                                            <div class="modal-body">
                                                <div class="form-group">
                                                    <label>Status</label>
                                                    <select name="status" class="form-control">
                                                        <option value="Pending" selected="@(order.Status == "Pending")">Pending</option>
                                                        <option value="Processing" selected="@(order.Status == "Processing")">Processing</option>
                                                        <option value="Completed" selected="@(order.Status == "Completed")">Completed</option>
                                                        <option value="Cancelled" selected="@(order.Status == "Cancelled")">Cancelled</option>
                                                    </select>
                                                </div>
                                                <div class="form-group">
                                                    <label>Notes (Optional)</label>
                                                    <textarea name="notes" class="form-control" rows="3"></textarea>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                                <button type="submit" class="btn btn-primary">Update Status</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                                                }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>