@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="~/css/admin.css" />

<div class="admin-wrapper">

    <!-- Simple Header -->
    <div class="admin-header">
        <h1>
            <i class="fas fa-chart-pie"></i>
            Dashboard <span>Overview</span>
        </h1>
        <div class="date-badge">
            <i class="far fa-calendar"></i>
            @DateTime.Now.ToString("dd MMM yyyy")
        </div>
    </div>

    <!-- Simple Stats Row - Will Wrap Automatically -->
    <div class="stats-row">
        <div class="stat-box">
            <div class="label">Total Orders</div>
            <div class="value">@(ViewBag.Statistics?.TotalOrders ?? 0)</div>
            <div class="footer">All time</div>
        </div>

        <div class="stat-box">
            <div class="label">Pending</div>
            <div class="value">@(ViewBag.Statistics?.PendingOrders ?? 0)</div>
            <div class="footer">
                <a href="@Url.Action("Orders", "Admin", new { status = "Pending", key = Context.Request.Query["key"] })">
                    View →
                </a>
            </div>
        </div>

        <div class="stat-box">
            <div class="label">Today's Revenue</div>
            <div class="value">R @(ViewBag.Statistics?.TodayRevenue?.ToString("N0") ?? "0")</div>
            <div class="footer">Today's sales</div>
        </div>

        <div class="stat-box">
            <div class="label">Total Revenue</div>
            <div class="value">R @(ViewBag.Statistics?.TotalRevenue?.ToString("N0") ?? "0")</div>
            <div class="footer">Lifetime earnings</div>
        </div>
    </div>

    <!-- Recent Orders Card -->
    <div class="card">
        <div class="card-header">
            <h2>
                <i class="fas fa-history"></i>
                Recent Orders
            </h2>
            <a href="@Url.Action("Orders", "Admin", new { key = Context.Request.Query["key"] })"
               class="btn-view">
                View All Orders
            </a>
        </div>
        <div class="card-body">
            @{
                var recentOrders = ViewBag.RecentOrders as List<LindisBakery.Models.Order>;
            }

            @if (recentOrders != null && recentOrders.Any())
            {
                <table>
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in recentOrders)
                        {
                            <tr>
                                <td>
                                    <span class="order-number">#@order.OrderNumber</span>
                                </td>
                                <td>
                                    <div class="customer-info">
                                        <div class="avatar">
                                            @(order.CustomerName?.Substring(0, 1).ToUpper() ?? "?")
                                        </div>
                                        <div class="customer-details">
                                            <div class="name">@order.CustomerName</div>
                                            <div class="contact">@order.CustomerEmail</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@order.OrderDate.ToString("dd MMM HH:mm")</td>
                                <td>
                                    <span class="items-badge">
                                        <i class="fas fa-box"></i>
                                        @(order.Items?.Sum(oi => oi.Quantity) ?? 0)
                                    </span>
                                </td>
                                <td class="total">R @order.Total.ToString("N0")</td>
                                <td>
                                    <span class="status @order.Status.ToLower()">
                                        @order.Status
                                    </span>
                                </td>
                                <td>
                                    <div class="actions">
                                        <a href="@Url.Action("OrderDetail", "Admin", new { id = order.Id, key = Context.Request.Query["key"] })"
                                           class="action-btn btn-view-order"
                                           title="View">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <button onclick="openStatusModal(@order.Id, '@order.OrderNumber', '@order.Status', '@order.CustomerName', '@order.Total')"
                                                class="action-btn btn-edit-order"
                                                title="Update Status">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-shopping-bag"></i>
                    <p>No recent orders</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Simple Status Modal -->
<div class="modal" id="statusModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-edit"></i> Update Order Status</h3>
        </div>
        <form action="@Url.Action("UpdateOrderStatus", "Admin")" method="post">
            <input type="hidden" name="id" id="modalOrderId" />
            <input type="hidden" name="key" value="@Context.Request.Query["key"]" />

            <div class="modal-body">
                <div class="form-group">
                    <label>Order #<span id="modalOrderNumber"></span></label>
                    <p><small id="modalCustomerInfo"></small></p>
                </div>

                <div class="form-group">
                    <label>Status</label>
                    <select name="status" class="form-control" id="modalStatus">
                        <option value="Pending">Pending</option>
                        <option value="Processing">Processing</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Notes (Optional)</label>
                    <textarea name="notes" class="form-control" rows="3" placeholder="Add notes..."></textarea>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" onclick="closeStatusModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Update Status</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openStatusModal(id, orderNumber, currentStatus, customerName, total) {
            document.getElementById('modalOrderId').value = id;
            document.getElementById('modalOrderNumber').textContent = ' ' + orderNumber;
            document.getElementById('modalCustomerInfo').textContent = customerName + ' - R ' + total;
            document.getElementById('modalStatus').value = currentStatus;
            document.getElementById('statusModal').classList.add('show');
        }

        function closeStatusModal() {
            document.getElementById('statusModal').classList.remove('show');
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            var modal = document.getElementById('statusModal');
            if (event.target == modal) {
                closeStatusModal();
            }
        }

        // Auto-hide alerts
        setTimeout(() => {
            document.querySelectorAll('.alert').forEach(alert => {
                alert.style.display = 'none';
            });
        }, 5000);
    </script>
}