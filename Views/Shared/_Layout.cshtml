@inject LindisBakery.Models.ShoppingCart Cart

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lindi's Bakery - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const hamburger = document.querySelector("#header .hamburger");
        const navMenu = document.querySelector("#header .nav-list ul");

        hamburger.addEventListener("click", function () {
            hamburger.classList.toggle("active");
            navMenu.classList.toggle("active");
        });
    });
</script>

<body>

    <!-- Header -->
    <section id="header">
        <div class="header container">
            <div class="nav-bar">
                <div class="brand">
                    <a href="#hero">
                        <h1>Lindi's Home Bakery</h1>
                    </a>
                </div>
                <div class="hamburger">
                    <div class="bar"></div>
                </div>

                <div class="nav-list">
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Home" asp-action="Menu">Menu</a></li>
                        <li><a asp-controller="Home" asp-action="About">About Us</a></li>
                        <li><a asp-controller="Home" asp-action="Contacts">Contact</a></li>
                       <li> <a asp-controller="Home" asp-action="Cart" class="cart-link">
                            <i class="bi bi-cart3"></i>
                            <span class="cart-text">Cart</span>
                            <span id="cart-count" class="cart-count-badge">0</span></a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
    <!-- End Header -->
   

    <main class="container main-content">
        
        @RenderBody()
    </main>

    <div id="cartToast" class="cart-toast">
    ✔ Added to cart
</div>


    <!-- Footer -->
    <section id="footer">
        <div class="footer container">
            <div class="brand">
                <h1>Lindi's Home Bakery </h1>
            </div>
            <h2>Love and flavor</h2>

           
            <p>Copyright © 2025 Lindi's Home bakery. All rights reserved</p>
        </div>
    </section>

    <script src="~/js/site.js" asp-append-version="true"></script>
    

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    @RenderSection("Scripts", required: false)

  

    

    
</body>
</html>